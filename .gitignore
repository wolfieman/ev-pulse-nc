# EV Pulse NC - North Carolina Electric Vehicle Analytics
# .gitignore

# ============================================================================
# Large Data Files (tracked by Git LFS via .gitattributes)
# ============================================================================
# CSV and XLSX files are tracked by Git LFS - do NOT ignore them
# SAS data files - ignore (too large, binary)
*.sas7bdat
*.sas7bcat

# ============================================================================
# SAS Files
# ============================================================================
# SAS temporary files
*.log
*.lst
*.sas7bndx
work/
saswork/
sastemp/

# SAS WORK library
SASWORK*/
!SASWORK*/.gitkeep

# SAS catalog files
*.sas7bcat
*.sc2

# SAS output files
*.rtf
*.pdf
*.html
!paper/*.pdf
!docs/**/*.pdf
!output/figures/*.pdf

# ============================================================================
# Python
# ============================================================================
# Build artifacts
build/
*.egg-info/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
env/
ENV/
.venv

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb_checkpoints

# ============================================================================
# R (if used)
# ============================================================================
.Rhistory
.RData
.Rproj.user

# ============================================================================
# Data Science / Analytics
# ============================================================================
# Processed data (keep raw in Git LFS)
data/processed/*.csv
data/processed/*.parquet

# Model artifacts
*.pkl
*.pickle
*.joblib
*.h5
*.hdf5

# ============================================================================
# IDE / Editor
# ============================================================================
# VS Code
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml

# Claude Code
.claude/

# SAS Studio / Enterprise Guide
*.egp
*.egp.bak

# ============================================================================
# OS Generated
# ============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ============================================================================
# Documentation
# ============================================================================
# MS Office temporary files
~$*.docx
~$*.xlsx
~$*.pptx
*.tmp

# ============================================================================
# Git LFS
# ============================================================================
# Track these large files with Git LFS (uncomment after LFS init)
# See: git lfs track "*.csv"
# .gitattributes will handle LFS patterns

# ============================================================================
# Project Specific
# ============================================================================
# Scratch / working files
scratch/
temp/
tmp/

# Credentials (if any API keys used)
.env
.env.local
credentials.json
secrets/

# Output archives
*.zip
*.tar.gz
!submission/*.zip

# ============================================================================
# Report Deliverables
# ============================================================================
# Keep final report materials
!paper/*.docx

# ============================================================================
# Paper Working Files (kept local while manuscript is in preparation)
# ============================================================================
paper/PAPER-NOTES.md
paper/SOURCE-INVENTORY.md
paper/MANUSCRIPT-PREP.md
paper/MANUSCRIPT-OUTLINE.md
paper/consultation-manuscript-outline.md
paper/manuscript.md
paper/appendix-c-ai-workflow.md
paper/sources/

# Claude local settings (machine-specific)
.claude/settings.local.json
