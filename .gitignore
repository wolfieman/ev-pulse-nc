# EV Pulse NC - North Carolina Electric Vehicle Analytics
# .gitignore

# ============================================================================
# Large Data Files (tracked by Git LFS via .gitattributes)
# ============================================================================
# CSV and XLSX files are tracked by Git LFS - do NOT ignore them
# SAS data files - ignore (too large, binary)
*.sas7bdat
*.sas7bcat

# ============================================================================
# SAS Files
# ============================================================================
# SAS temporary files
*.log
*.lst
*.sas7bndx
work/
saswork/
sastemp/

# SAS WORK library
SASWORK*/
!SASWORK*/.gitkeep

# SAS catalog files
*.sas7bcat
*.sc2

# SAS output files
*.rtf
*.pdf
*.html
!paper/*.pdf
!docs/**/*.pdf
!output/figures/*.pdf
!conferences/**/*.pdf
!competitions/**/*.pdf

# ============================================================================
# Python
# ============================================================================
# Build artifacts
build/
*.egg-info/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
env/
ENV/
.venv

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb_checkpoints

# ============================================================================
# R (if used)
# ============================================================================
.Rhistory
.RData
.Rproj.user

# ============================================================================
# Data Science / Analytics
# ============================================================================
# Processed data (keep raw in Git LFS)
data/processed/*.csv
data/processed/*.parquet

# Model artifacts
*.pkl
*.pickle
*.joblib
*.h5
*.hdf5

# ============================================================================
# IDE / Editor
# ============================================================================
# VS Code
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml

# Claude Code — track CLAUDE.md, keep local settings/state ignored
.claude/*
!.claude/CLAUDE.md

# SAS Studio / Enterprise Guide
*.egp
*.egp.bak

# ============================================================================
# OS Generated
# ============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ============================================================================
# Documentation
# ============================================================================
# MS Office temporary files
~$*.docx
~$*.xlsx
~$*.pptx
*.tmp

# ============================================================================
# Git LFS
# ============================================================================
# Track these large files with Git LFS (uncomment after LFS init)
# See: git lfs track "*.csv"
# .gitattributes will handle LFS patterns

# ============================================================================
# Project Specific
# ============================================================================
# Scratch / working files
scratch/
temp/
tmp/

# Internal working docs — kept local, not published to the public repo
docs/internal/

# Private LinkedIn-strategy consultation — kept local
docs/blog/consultation.md

# AI methodology disclosure PDF — kept local pending a scrubbed regeneration.
# Placed after the `!docs/**/*.pdf` whitelist (above) so this re-ignore wins.
docs/research/ai-methodology-disclosure.pdf

# Credentials (if any API keys used)
.env
.env.local
credentials.json
secrets/

# Output archives
*.zip
*.tar.gz
!submission/*.zip

# ============================================================================
# Report Deliverables
# ============================================================================
# Word documents are editable sources for PDF supplementary materials,
# kept local-only. PDFs are the canonical public artifact.
*.docx
!paper/*.docx
# Manuscript .docx is regenerable from code/python/paper/build_docx.py;
# the PDF (paper/ev-pulse-nc-sanyer-paper.pdf) is the canonical public artifact.
paper/manuscript.docx

# PowerPoint presentation decks are deliverables for Canvas/email but
# not pushed to the public repo (heavy binaries, regenerable from the
# Gamma source via deliverables/final-presentation/presentation-outline.txt
# in the BIDA 670 repo).
*.pptx

# Video recordings of presentations / demos — heavy binaries, kept
# local-only. PDF of the presentation is the canonical pushed artifact.
*.mp4

# ============================================================================
# Paper Working Files (kept local while manuscript is in preparation)
# ============================================================================
paper/PAPER-NOTES.md
paper/SOURCE-INVENTORY.md
paper/MANUSCRIPT-PREP.md
paper/MANUSCRIPT-OUTLINE.md
paper/consultation-manuscript-outline.md
paper/manuscript.md
paper/sources/

# ============================================================================
# Conference Working Files (kept local — never tracked or pushed)
# ============================================================================
# conferences/ allows tracked PDFs (CFPs, programs, accepted-paper PDFs),
# but draft submissions, scratch work, and reviewer correspondence should
# stay local. These subdirectory names are reserved for that purpose.
conferences/**/drafts/
conferences/**/scratch/
conferences/**/correspondence/

# Claude local settings (machine-specific)
.claude/settings.local.json
